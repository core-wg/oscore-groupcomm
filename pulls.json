    "title": "Move signature to Payload and Compression updates",
    "user": {
      "login": "emanjon",
      "id": 24212834,
      "node_id": "MDQ6VXNlcjI0MjEyODM0",
      "avatar_url": "https://avatars3.githubusercontent.com/u/24212834?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/emanjon",
      "html_url": "https://github.com/emanjon",
      "followers_url": "https://api.github.com/users/emanjon/followers",
      "following_url": "https://api.github.com/users/emanjon/following{/other_user}",
      "gists_url": "https://api.github.com/users/emanjon/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/emanjon/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/emanjon/subscriptions",
      "organizations_url": "https://api.github.com/users/emanjon/orgs",
